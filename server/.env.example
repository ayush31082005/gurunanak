PORT=5000
NODE_ENV=development

# MongoDB
# If your password contains special characters like @, :, /, ?, # then URL-encode them.
MONGO_URI=mongodb+srv://your_username:your_password%4012345@cluster0.example.mongodb.net/your_database?appName=Cluster0
# Optional fallbacks
# MONGO_URI_FALLBACK=mongodb://127.0.0.1:27017/your_database
# DNS_SERVERS=1.1.1.1,8.8.8.8

# Auth
JWT_SECRET=your_super_secret_key
ADMIN_SETUP_KEY=change_this_admin_setup_key

# Client
CLIENT_URL=http://localhost:5173

# Email (SMTP / Gmail app password)
EMAIL=your_email@example.com
EMAIL_USER=your_email@example.com
EMAIL_PASS=your_email_app_password
CONTACT_EMAIL=your_email@example.com
SUPPORT_EMAIL=your_email@example.com
STOCK_ALERT_EMAIL=your_email@example.com
PRESCRIPTION_NOTIFICATION_EMAIL=your_email@example.com
ORDER_NOTIFICATION_EMAIL=your_email@example.com
CALLBACK_NOTIFICATION_EMAIL=your_email@example.com

# Cloudinary
CLOUDINARY_URL=cloudinary://your_api_key:your_api_secret@your_cloud_name
CLOUD_NAME=your_cloud_name
API_KEY=your_api_key
API_SECRET=your_api_secret

# Razorpay
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
